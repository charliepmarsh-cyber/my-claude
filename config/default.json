{
  "pipeline": {
    "llmRateLimit": 20,
    "enrichmentEnabled": true,
    "scoringEnabled": true,
    "draftingEnabled": true,
    "channels": ["linkedin", "x", "email"],
    "minScoreForDrafting": 30,
    "excludeTierD": true,
    "dryRun": false
  },
  "scoring": {
    "weights": {
      "fit": 0.30,
      "opportunity": 0.35,
      "urgency": 0.20,
      "personalization": 0.15
    },
    "tierThresholds": {
      "A": 75,
      "B": 50,
      "C": 30,
      "D": 0
    }
  },
  "quality": {
    "minPersonalizationLength": 10,
    "maxLinkedInConnectionNote": 300,
    "maxXDm": 300,
    "maxEmailWords": 200,
    "maxEmailSubject": 60,
    "duplicateThreshold": 0.8
  }
}
