{
  "name": "CortexCart — Weekly Export Approved Leads",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 17 * * 5" }]
        }
      },
      "name": "Schedule (Fridays 5pm)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.OUTREACH_BASE_URL}}/webhook/export?status=approved",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "name": "Fetch Approved Leads",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            { "value1": "={{$json.count}}", "operation": "larger", "value2": 0 }
          ]
        }
      },
      "name": "Has Leads?",
      "type": "n8n-nodes-base.if",
      "position": [680, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "leads",
        "options": {}
      },
      "name": "Split Leads",
      "type": "n8n-nodes-base.splitOut",
      "position": [900, 200]
    },
    {
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": { "__rl": true, "mode": "id", "value": "={{$env.GOOGLE_SHEET_ID}}" },
        "sheetName": "Approved Leads",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Company": "={{$json.companyName}}",
            "Contact": "={{$json.contactName}}",
            "Email": "={{$json.contactEmail}}",
            "LinkedIn": "={{$json.linkedinUrl}}",
            "Score": "={{$json.score}}",
            "Tier": "={{$json.tier}}",
            "Segment": "={{$json.segment}}",
            "Status": "={{$json.status}}",
            "Drafts": "={{$json.draftCount}}",
            "Exported": "={{$now.toISO()}}"
          }
        },
        "options": {}
      },
      "name": "Google Sheets",
      "type": "n8n-nodes-base.googleSheets",
      "position": [1120, 200]
    },
    {
      "parameters": {
        "channel": "#sales-leads",
        "text": "📊 *Weekly Export*\nExported {{$json.count}} approved leads to Google Sheets.\n\nReview: {{$env.GOOGLE_SHEET_URL}}"
      },
      "name": "Slack Summary",
      "type": "n8n-nodes-base.slack",
      "position": [1340, 200]
    }
  ],
  "connections": {
    "Schedule (Fridays 5pm)": { "main": [[{ "node": "Fetch Approved Leads", "type": "main", "index": 0 }]] },
    "Fetch Approved Leads": { "main": [[{ "node": "Has Leads?", "type": "main", "index": 0 }]] },
    "Has Leads?": { "main": [[{ "node": "Split Leads", "type": "main", "index": 0 }], []] },
    "Split Leads": { "main": [[{ "node": "Google Sheets", "type": "main", "index": 0 }]] },
    "Google Sheets": { "main": [[{ "node": "Slack Summary", "type": "main", "index": 0 }]] }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
