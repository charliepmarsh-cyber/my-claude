{
  "name": "CortexCart — Daily Lead Discovery",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 8 * * 1-5" }]
        }
      },
      "name": "Schedule (Weekdays 8am)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.OUTREACH_BASE_URL}}/webhook/discover",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "segment", "value": "shopify" },
            { "name": "maxLeads", "value": "25" },
            { "name": "runPipeline", "value": "true" }
          ]
        },
        "options": { "timeout": 10000 }
      },
      "name": "Trigger Discovery",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "amount": 5,
        "unit": "minutes"
      },
      "name": "Wait 5 min",
      "type": "n8n-nodes-base.wait",
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.OUTREACH_BASE_URL}}/webhook/status?jobId={{$json.jobId}}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth"
      },
      "name": "Check Job Status",
      "type": "n8n-nodes-base.httpRequest",
      "position": [900, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            { "value1": "={{$json.job.status}}", "value2": "completed" }
          ]
        }
      },
      "name": "Job Completed?",
      "type": "n8n-nodes-base.if",
      "position": [1120, 300]
    },
    {
      "parameters": {
        "channel": "#sales-leads",
        "text": "🔍 *Daily Discovery Complete*\n• Total found: {{$json.job.result.totalFound}}\n• New leads: {{$json.job.result.totalNew}}\n• Queued for review: {{$json.job.result.pipelineResult.queued || 0}}\n\nReview at: {{$env.OUTREACH_BASE_URL}}/webhook/leads?status=review_pending"
      },
      "name": "Slack Notification",
      "type": "n8n-nodes-base.slack",
      "position": [1340, 200]
    }
  ],
  "connections": {
    "Schedule (Weekdays 8am)": { "main": [[{ "node": "Trigger Discovery", "type": "main", "index": 0 }]] },
    "Trigger Discovery": { "main": [[{ "node": "Wait 5 min", "type": "main", "index": 0 }]] },
    "Wait 5 min": { "main": [[{ "node": "Check Job Status", "type": "main", "index": 0 }]] },
    "Check Job Status": { "main": [[{ "node": "Job Completed?", "type": "main", "index": 0 }]] },
    "Job Completed?": { "main": [[{ "node": "Slack Notification", "type": "main", "index": 0 }], []] }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
