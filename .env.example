# Anthropic API key for Claude-powered enrichment and drafting
ANTHROPIC_API_KEY=sk-ant-...

# Database path (defaults to ./data/outreach.db)
DATABASE_PATH=./data/outreach.db

# Default output directory
OUTPUT_DIR=./output

# Rate limiting: max LLM calls per minute
LLM_RATE_LIMIT=20

# ── Discovery Connector API Keys ──────────────────────────────
# Apollo.io — people/company search (https://www.apollo.io/)
APOLLO_API_KEY=

# BuiltWith — tech stack detection (https://builtwith.com/)
BUILTWITH_API_KEY=

# Hunter.io — email finding (https://hunter.io/)
HUNTER_API_KEY=

# Discovery defaults
DISCOVERY_DEFAULT_MAX=25
DISCOVERY_ENABLED_SOURCES=apollo,builtwith,jobsignals

# Optional: n8n webhook URL for notifications
N8N_WEBHOOK_URL=

# Optional: email provider (sendgrid | resend | smtp)
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=

# Logging level (debug | info | warn | error)
LOG_LEVEL=info
