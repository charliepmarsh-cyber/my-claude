# Anthropic API key for Claude-powered enrichment and drafting
ANTHROPIC_API_KEY=sk-ant-...

# Database path (defaults to ./data/outreach.db)
DATABASE_PATH=./data/outreach.db

# Default output directory
OUTPUT_DIR=./output

# Rate limiting: max LLM calls per minute
LLM_RATE_LIMIT=20

# Optional: n8n webhook URL for notifications
N8N_WEBHOOK_URL=

# Optional: email provider (sendgrid | resend | smtp)
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=

# Logging level (debug | info | warn | error)
LOG_LEVEL=info
